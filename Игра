import os
import time
import random

class MatchstickGame:
    def __init__(self):
        self.player_name = ""
        self.current_level = 1
        self.max_level = 3
        self.score = 0
        self.secret_clues = 0  # Счётчик секретных подсказок
        self.secret_unlocked = False
        
    def clear_screen(self):
        """Очистка экрана для лучшей читаемости"""
        os.system('cls' if os.name == 'nt' else 'clear')
    
    def print_slow(self, text, delay=0.05):
        """Печать текста с эффектом печатной машинки (медленнее)"""
        for char in text:
            print(char, end='', flush=True)
            time.sleep(delay)
        print()
    
    def wait_for_enter(self, text="Нажми Enter, чтобы продолжить..."):
        """Ожидание нажатия Enter с подсказкой"""
        print(f"\n{text}")
        input()
    
