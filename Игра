    def show_chapter_transition(self, chapter_num, chapter_title):
        """Показ перехода между главами"""
        self.clear_screen()
        print("\n" + "═" * 60)
        print(f"            ГЛАВА {chapter_num}: {chapter_title}")
        print("═" * 60)
        time.sleep(1)
        self.wait_for_enter("Нажми Enter, чтобы продолжить...")
    
