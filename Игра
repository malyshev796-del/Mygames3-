    def solve_level2(self):
        """Решение для уровня 2"""
        self.print_slow("\nТы рассматриваешь домик...", 0.04)
        time.sleep(1.5)
        
        # Если секрет разблокирован, добавляем особый вариант
        secret_option = ""
        if self.secret_unlocked:
            secret_option = "5. 🕺 Сложить спички в человечка (странно, но попробуй)"
        
        attempts = 0
        while attempts < 3:
            print("\nЧто будешь делать?")
            print("1. Убрать спички с крыши внутрь квадрата")
            print("2. Сломать крышу и сделать три маленьких квадрата")
            print("3. Превратить домик в лестницу")
            print("4. Попросить подсказку")
            if secret_option:
                print(secret_option)
            
            choice = input("Твой выбор (1-5): ")
            
            if choice == "1":
                self.print_slow("\nТы убираешь две спички с крыши и кладёшь их внутрь квадрата...", 0.04)
                time.sleep(1)
                self.print_slow("Получается разделение на три маленьких квадрата!", 0.04)
                self.print_slow('\nТорвальд восклицает: "Да! Именно так! Сигни была в восторге!"', 0.04)
                time.sleep(1.5)
                return True
            elif choice == "2":
                self.print_slow("\nТы ломаешь крышу, но квадраты получаются разного размера...", 0.04)
                self.print_slow('Торвальд вздыхает: "Не совсем правильно..."', 0.04)
                time.sleep(1)
            elif choice == "3":
                self.print_slow("\nПолучается странная конструкция, похожая на лестницу.", 0.04)
                self.print_slow('Торвальд: "Это не то..."', 0.04)
                time.sleep(1)
            elif choice == "4":
                self.print_slow('\nТорвальд: "Посмотри на крышу. Если убрать два ската и положить их внутрь квадрата вертикально..."', 0.04)
                self.print_slow('"Ты разделишь большой квадрат на три маленьких!"', 0.04)
                time.sleep(2)
            elif choice == "5" and secret_option:
                self.print_slow("\nТы начинаешь складывать спички в фигурку человечка...", 0.04)
                time.sleep(1)
                self.print_slow("И вдруг слышишь музыку!", 0.04)
                time.sleep(1)
                return self.secret_stickman_dance()
            else:
                print("Пожалуйста, выбери 1-5")
            
            attempts += 1
        
        self.print_slow("\nТы перепробовал много вариантов и наконец нашёл решение!", 0.04)
        return True
    
