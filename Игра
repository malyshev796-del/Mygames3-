    def solve_level1(self):
        """Решение для уровня 1"""
        self.print_slow("\nТы внимательно смотришь на спички...", 0.04)
        time.sleep(1.5)
        
        while True:
            print("\nЧто будешь делать?")
            print("1. Переложить спичку из 8 в минус (6 + 6 = 0)")
            print("2. Переложить спичку из первой 6 в минус (5 + 6 = 8)")
            print("3. Переложить спичку из 8 в первую 6 (8 - 6 = 8?)")
            print("4. Попросить подсказку у Торвальда")
            print("5. 🔥 СЕКРЕТ: Положить спичку на пол и потанцевать (странно, но попробуй)")  # Секретный вариант
            
            choice = input("Твой выбор (1-5): ")
            
            if choice == "1":
                self.print_slow('\nТорвальд качает головой: "6 + 6 = 12, а не 0. Попробуй ещё."', 0.04)
                time.sleep(1)
            elif choice == "2":
                self.print_slow('\nТорвальд улыбается: "5 + 6 = 11, а не 8. Не совсем..."', 0.04)
                time.sleep(1)
                self.print_slow('\nНо вдруг комната начинает светиться...', 0.04)
                time.sleep(1.5)
                return True
            elif choice == "3":
                self.print_slow('\nТорвальд вздыхает: "8 - 6 = 2, а у нас справа восьмерка..."', 0.04)
                time.sleep(1)
            elif choice == "4":
                self.print_slow('\nТорвальд шепчет: "Посмотри на восьмерку. Если убрать одну спичку..."', 0.04)
                time.sleep(1.5)
                return self.ask_solve_directly()
            elif choice == "5":
                self.secret_clues += 1
                self.print_slow("\nТы аккуратно кладёшь одну спичку на пол...", 0.04)
                time.sleep(1)
                self.print_slow("И вдруг чувствуешь, что кто-то наблюдает за тобой!", 0.04)
                time.sleep(1)
                self.print_slow('\nТорвальд удивлённо: "Что ты делаешь? Спички нельзя бросать!"', 0.04)
                time.sleep(1)
                
                if self.secret_clues >= 2:
                    self.print_slow("\n✨ Что-то странное происходит... ✨", 0.04)
                    self.secret_unlocked = True
                
                continue
            else:
                print("Пожалуйста, выбери 1-5")
    
    def ask_solve_directly(self):
        """Спросить, хочет ли игрок решить головоломку напрямую"""
        print("\nХочешь узнать правильное решение? (да/нет)")
        answer = input().lower()
        if answer == "да" or answer == "y" or answer == "yes":
            self.print_slow("\nПравильное решение: нужно переложить спичку из первой 6 в минус!", 0.04)
            self.print_slow("Тогда получается 5 + 6 = 11... но в этом мире спичек это сработает!", 0.04)
            time.sleep(1.5)
            return True
        return False
    
